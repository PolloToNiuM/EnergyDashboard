# RTE OAuth Basic credential, without or with the "Basic " prefix.
RTE_BASIC_AUTH=

# PostgreSQL connection string used by backend and ingestion loaders.
DATABASE_URL=postgresql+psycopg://energy_scope:energy_scope@localhost:5432/energy_scope

# Open-Meteo locations used by weather ingestion.
# Format: Name:latitude:longitude,Name:latitude:longitude
WEATHER_LOCATIONS=Lille:50.6292:3.0573,Paris:48.8566:2.3522,Strasbourg:48.5734:7.7521,Lyon:45.7640:4.8357,Marseille:43.2965:5.3698,Toulouse:43.6047:1.4442,Bordeaux:44.8378:-0.5792,Nantes:47.2184:-1.5536,Brest:48.3904:-4.4861
WEATHER_AVERAGE_ZONE=France
WEATHER_TIMEZONE=Europe/Paris
WEATHER_HOURLY_VARIABLES=temperature_2m,shortwave_radiation,wind_speed_100m

# Logging levels used by the backend.
LOG_LEVEL=INFO
SQLALCHEMY_LOG_LEVEL=WARNING
UVICORN_ACCESS_LOG_LEVEL=WARNING
HTTPX_LOG_LEVEL=WARNING
HTTPCORE_LOG_LEVEL=WARNING
